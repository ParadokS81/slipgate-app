# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for all common source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.lock text eol=lf

# Binary files — don't touch
*.png binary
*.ico binary
*.icns binary
